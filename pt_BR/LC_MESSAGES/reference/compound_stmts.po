msgstr "Em termos simples, ``(P)`` tem o mesmo efeito que ``P``."

#: ../../reference/compound_stmts.rst:951
msgid "Sequence Patterns"
msgstr "PadrĂ”es de sequĂȘncia"

#: ../../reference/compound_stmts.rst:953
