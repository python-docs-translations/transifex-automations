#: ../../reference/compound_stmts.rst:937
msgid "Group Patterns"
msgstr "PadrĂ”es de grupo"

#: ../../reference/compound_stmts.rst:939
msgid ""
"A group pattern allows users to add parentheses around patterns to emphasize "
