"referĂŞncias desnecessĂˇrias durante a depuraĂ§ĂŁo de vazamento de referĂŞncia."

#: ../../library/sys.rst:195 ../../library/sys.rst:222
#: ../../library/sys.rst:235
msgid ""
"This function should be used for internal and specialized purposes only."
msgstr "Esta funĂ§ĂŁo deve ser usada apenas para fins internos e especializados."

#: ../../library/sys.rst:197
