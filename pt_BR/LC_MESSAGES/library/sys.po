msgstr ""
"Uma funĂ§ĂŁo (ou outro bloco de cĂłdigo) estĂˇ prestes a retornar. A funĂ§ĂŁo de "
"perfilaĂ§ĂŁo Ă© chamada; *arg* Ă© o valor que serĂˇ retornado, ou ``None`` se o "
"evento for causado por uma exceĂ§ĂŁo sendo levantada."

#: ../../library/sys.rst:1710
msgid "``'c_call'``"
msgstr "``'c_call'``"

#: ../../library/sys.rst:1711
msgid ""
