"{\n"
"    PyStatus status;\n"
"    PyConfig config;\n"
"    PyConfig_InitPythonConfig(&config);\n"
"\n"
"    /* LûÊgg till en inbyggd modul, fûÑre Py_Initialize */\n"
"    if (PyImport_AppendInittab(\"spam\", PyInit_spam) == -1) {\n"
"        fprintf(stderr, \"Fel: kunde inte utûÑka inbyggda moduler "
"table\\n\");\n"
"        exit(1);\n"
"    }\n"
"\n"
