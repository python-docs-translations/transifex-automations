"\"<Match: '727ak', groups=()>\""

#: ../../library/re.rst:1621
msgid ""
"That last hand, ``\"727ak\"``, contained a pair, or two of the same valued "
"cards. To match this with a regular expression, one could use backreferences"
" as such::"
msgstr "жЬАеРОдЄАжЙЛзЙМпЉМ``\"727ak\"`` пЉМеМЕеРЂдЇЖдЄАдЄ™еѓєе≠РпЉМжИЦиАЕдЄ§еЉ†еРМж†ЈжХ∞еАЉзЪДзЙМгАВи¶БзФ®ж≠£еИЩи°®иЊЊеЉПеМєйЕНеЃГпЉМеЇФиѓ•дљњзФ®еРСеРОеЉХзФ®е¶ВдЄЛ ::"

#: ../../library/re.rst:1624
msgid ""
">>> pair = re.compile(r\".*(.).*\\1\")\n"
">>> displaymatch(pair.match(\"717ak\"))     # Pair of 7s.\n"
"\"<Match: '717', groups=('7',)>\"\n"
">>> displaymatch(pair.match(\"718ak\"))     # No pairs.\n"
">>> displaymatch(pair.match(\"354aa\"))     # Pair of aces.\n"
"\"<Match: '354aa', groups=('a',)>\""
msgstr ""
">>> pair = re.compile(r\".*(.).*\\1\")\n"
">>> displaymatch(pair.match(\"717ak\"))     # жИРеѓєзЪД 7гАВ\n"
"\"<Match: '717', groups=('7',)>\"\n"
">>> displaymatch(pair.match(\"718ak\"))     # ж≤°жЬЙжИРеѓєгАВ\n"
">>> displaymatch(pair.match(\"354aa\"))     # жИРеѓєзЪД aгАВ\n"
