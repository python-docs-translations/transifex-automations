msgid ""
"This module provides access to operating system functionality that is "
"standardized by the C Standard and the POSIX standard (a thinly disguised "
"Unix interface)."
msgstr ""
"–≠—В–Њ—В –Љ–Њ–і—Г–ї—М –Њ–±–µ—Б–њ–µ—З–Є–≤–∞–µ—В –і–Њ—Б—В—Г–њ –Ї —Д—Г–љ–Ї—Ж–Є—П–Љ –Њ–њ–µ—А–∞—Ж–Є–Њ–љ–љ–Њ–є —Б–Є—Б—В–µ–Љ—Л, "
"—Б—В–∞–љ–і–∞—А—В–Є–Ј–Є—А–Њ–≤–∞–љ–љ—Л–Љ —Б—В–∞–љ–і–∞—А—В–Њ–Љ C –Є —Б—В–∞–љ–і–∞—А—В–Њ–Љ POSIX (—В–Њ–љ–Ї–Њ –Ј–∞–Љ–∞—Б–Ї–Є—А–Њ–≤–∞–љ–љ—Л–є "
"–Є–љ—В–µ—А—Д–µ–є—Б Unix)."

#: ../../library/posix.rst:14
msgid "Availability"
msgstr "–Ф–Њ—Б—В—Г–њ–љ–Њ—Б—В—М"

#: ../../library/posix.rst:18
msgid ""
"**Do not import this module directly.**  Instead, import the "
"module :mod:`os`, which provides a *portable* version of this interface.  On "
"Unix, the :mod:`os` module provides a superset of the :mod:`posix` "
"interface.  On non-Unix operating systems the :mod:`posix` module is not "
"available, but a subset is always available through the :mod:`os` "
"interface.  Once :mod:`os` is imported, there is *no* performance penalty in "
"using it instead of :mod:`posix`.  In addition, :mod:`os` provides some "
"additional functionality, such as automatically calling :func:`~os.putenv` "
"when an entry in ``os.environ`` is changed."
msgstr ""
"**–Э–µ –Є–Љ–њ–Њ—А—В–Є—А—Г–є—В–µ —Н—В–Њ—В –Љ–Њ–і—Г–ї—М –љ–∞–њ—А—П–Љ—Г—О.** –Т–Љ–µ—Б—В–Њ —Н—В–Њ–≥–Њ –Є–Љ–њ–Њ—А—В–Є—А—Г–є—В–µ "
"–Љ–Њ–і—Г–ї—М :mod:`os`, –Ї–Њ—В–Њ—А—Л–є –њ—А–µ–і–Њ—Б—В–∞–≤–ї—П–µ—В *–њ–Њ—А—В–∞—В–Є–≤–љ—Г—О* –≤–µ—А—Б–Є—О —Н—В–Њ–≥–Њ "
"–Є–љ—В–µ—А—Д–µ–є—Б–∞. –Т Unix –Љ–Њ–і—Г–ї—М :mod:`os` –њ—А–µ–і—Б—В–∞–≤–ї—П–µ—В —Б–Њ–±–Њ–є –љ–∞–і—Б—В—А–Њ–є–Ї—Г "
"–Є–љ—В–µ—А—Д–µ–є—Б–∞ :mod:`posix`. –Т –Њ–њ–µ—А–∞—Ж–Є–Њ–љ–љ—Л—Е —Б–Є—Б—В–µ–Љ–∞—Е, –Њ—В–ї–Є—З–љ—Л—Е –Њ—В Unix, "
"–Љ–Њ–і—Г–ї—М :mod:`posix` –љ–µ–і–Њ—Б—В—Г–њ–µ–љ, –љ–Њ –µ–≥–Њ –њ–Њ–і–Љ–љ–Њ–ґ–µ—Б—В–≤–Њ –≤—Б–µ–≥–і–∞ –і–Њ—Б—В—Г–њ–љ–Њ —З–µ—А–µ–Ј "
"–Є–љ—В–µ—А—Д–µ–є—Б :mod:`os`. –Я–Њ—Б–ї–µ –Є–Љ–њ–Њ—А—В–∞ :mod:`os` –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞–љ–Є–µ –µ–≥–Њ "
"–≤–Љ–µ—Б—В–Њ :mod:`posix` *–љ–µ—В* —Б–љ–Є–ґ–µ–љ–Є—П –њ—А–Њ–Є–Ј–≤–Њ–і–Є—В–µ–ї—М–љ–Њ—Б—В–Є. –Ъ—А–Њ–Љ–µ —В–Њ–≥–Њ, :mod:`os` "
"–њ—А–µ–і–Њ—Б—В–∞–≤–ї—П–µ—В –љ–µ–Ї–Њ—В–Њ—А—Л–µ –і–Њ–њ–Њ–ї–љ–Є—В–µ–ї—М–љ—Л–µ —Д—Г–љ–Ї—Ж–Є–Є, —В–∞–Ї–Є–µ –Ї–∞–Ї –∞–≤—В–Њ–Љ–∞—В–Є—З–µ—Б–Ї–Є–є "
"–≤—Л–Ј–Њ–≤ :func:`~os.putenv` –њ—А–Є –Є–Ј–Љ–µ–љ–µ–љ–Є–Є –Ј–∞–њ–Є—Б–Є –≤ ``os.environ``."

#: ../../library/posix.rst:27
msgid ""
"Errors are reported as exceptions; the usual exceptions are given for type "
"errors, while errors reported by the system calls raise :exc:`OSError`."
msgstr ""
"–Ю–± –Њ—И–Є–±–Ї–∞—Е —Б–Њ–Њ–±—Й–∞–µ—В—Б—П –Ї–∞–Ї –Њ–± –Є—Б–Ї–ї—О—З–µ–љ–Є—П—Е; –Њ–±—Л—З–љ—Л–µ –Є—Б–Ї–ї—О—З–µ–љ–Є—П –і–∞—О—В—Б—П –і–ї—П "
"–Њ—И–Є–±–Њ–Ї —В–Є–њ–∞, —В–Њ–≥–і–∞ –Ї–∞–Ї –Њ—И–Є–±–Ї–Є, –Њ –Ї–Њ—В–Њ—А—Л—Е —Б–Њ–Њ–±—Й–∞—О—В —Б–Є—Б—В–µ–Љ–љ—Л–µ –≤—Л–Ј–Њ–≤—Л, "
"–≤—Л–Ј—Л–≤–∞—О—В :exc:`OSError`."

#: ../../library/posix.rst:34
msgid "Large File Support"
msgstr "–Я–Њ–і–і–µ—А–ґ–Ї–∞ –±–Њ–ї—М—И–Є—Е —Д–∞–є–ї–Њ–≤"

#: ../../library/posix.rst:42
msgid ""
"Several operating systems (including AIX and Solaris) provide support for "
"files that are larger than 2 GiB from a C programming model "
"where :c:expr:`int` and :c:expr:`long` are 32-bit values. This is typically "
"accomplished by defining the relevant size and offset types as 64-bit "
"values. Such files are sometimes referred to as :dfn:`large files`."
msgstr ""
"–Э–µ–Ї–Њ—В–Њ—А—Л–µ –Њ–њ–µ—А–∞—Ж–Є–Њ–љ–љ—Л–µ —Б–Є—Б—В–µ–Љ—Л (–≤–Ї–ї—О—З–∞—П AIX –Є Solaris) –Њ–±–µ—Б–њ–µ—З–Є–≤–∞—О—В "
"–њ–Њ–і–і–µ—А–ґ–Ї—Г —Д–∞–є–ї–Њ–≤ —А–∞–Ј–Љ–µ—А–Њ–Љ –±–Њ–ї–µ–µ 2 –У–Є–С –Є–Ј –Љ–Њ–і–µ–ї–Є –њ—А–Њ–≥—А–∞–Љ–Љ–Є—А–Њ–≤–∞–љ–Є—П C, "
"–≥–і–µ :c:expr:`int` –Є :c:expr:`long` вАФ 32-–±–Є—В–љ—Л–µ –Ј–љ–∞—З–µ–љ–Є—П. –Ю–±—Л—З–љ–Њ —Н—В–Њ "
"–і–Њ—Б—В–Є–≥–∞–µ—В—Б—П –њ—Г—В–µ–Љ –Њ–њ—А–µ–і–µ–ї–µ–љ–Є—П —Б–Њ–Њ—В–≤–µ—В—Б—В–≤—Г—О—Й–Є—Е —В–Є–њ–Њ–≤ —А–∞–Ј–Љ–µ—А–∞ –Є —Б–Љ–µ—Й–µ–љ–Є—П –Ї–∞–Ї "
"64-–±–Є—В–љ—Л—Е –Ј–љ–∞—З–µ–љ–Є–є. –Ґ–∞–Ї–Є–µ —Д–∞–є–ї—Л –Є–љ–Њ–≥–і–∞ –љ–∞–Ј—Л–≤–∞—О—В :dfn:`–±–Њ–ї—М—И–Є–Љ–Є —Д–∞–є–ї–∞–Љ–Є`."

#: ../../library/posix.rst:48
msgid ""
"Large file support is enabled in Python when the size of an :c:type:`off_t` "
"is larger than a :c:expr:`long` and the :c:expr:`long long` is at least as "
"large as an :c:type:`off_t`. It may be necessary to configure and compile "
"Python with certain compiler flags to enable this mode. For example, with "
"Solaris 2.6 and 2.7 you need to do something like::"
msgstr ""
"–Я–Њ–і–і–µ—А–ґ–Ї–∞ –±–Њ–ї—М—И–Є—Е —Д–∞–є–ї–Њ–≤ –≤ Python –≤–Ї–ї—О—З–∞–µ—В—Б—П, –Ї–Њ–≥–і–∞ —А–∞–Ј–Љ–µ—А :c:type:`off_t` "
"–±–Њ–ї—М—И–µ, —З–µ–Љ :c:expr:`long`, –∞ :c:expr:`long long` –њ–Њ –Ї—А–∞–є–љ–µ–є –Љ–µ—А–µ —А–∞–≤–µ–љ "
"—А–∞–Ј–Љ–µ—А—Г :c:expr:`long long`. :c:type:`off_t`. –Ф–ї—П –≤–Ї–ї—О—З–µ–љ–Є—П —Н—В–Њ–≥–Њ —А–µ–ґ–Є–Љ–∞ "
"–Љ–Њ–ґ–µ—В –њ–Њ—В—А–µ–±–Њ–≤–∞—В—М—Б—П –љ–∞—Б—В—А–Њ–Є—В—М –Є —Б–Ї–Њ–Љ–њ–Є–ї–Є—А–Њ–≤–∞—В—М Python —Б –Њ–њ—А–µ–і–µ–ї–µ–љ–љ—Л–Љ–Є "
"—Д–ї–∞–≥–∞–Љ–Є –Ї–Њ–Љ–њ–Є–ї—П—В–Њ—А–∞. –Э–∞–њ—А–Є–Љ–µ—А, –≤ Solaris 2.6 –Є 2.7 –≤–∞–Љ –љ—Г–ґ–љ–Њ —Б–і–µ–ї–∞—В—М —З—В–Њ-—В–Њ "
"–≤—А–Њ–і–µ::"

#: ../../library/posix.rst:55
msgid ""
"CFLAGS=\"`getconf LFS_CFLAGS`\" OPT=\"-g -O2 $CFLAGS\" \\\n"
"        ./configure"
msgstr ""
"CFLAGS=\"`getconf LFS_CFLAGS`\" OPT=\"-g -O2 $CFLAGS\" \\\n"
"        ./configure"

#: ../../library/posix.rst:58
msgid "On large-file-capable Linux systems, this might work::"
msgstr "–Т —Б–Є—Б—В–µ–Љ–∞—Е Linux —Б –њ–Њ–і–і–µ—А–ґ–Ї–Њ–є –±–Њ–ї—М—И–Є—Е —Д–∞–є–ї–Њ–≤ —Н—В–Њ –Љ–Њ–ґ–µ—В —Б—А–∞–±–Њ—В–∞—В—М:"

#: ../../library/posix.rst:60
msgid ""
"CFLAGS='-D_LARGEFILE64_SOURCE -D_FILE_OFFSET_BITS=64' OPT=\"-g -O2 $CFLAGS\" "
"\\\n"
"        ./configure"
msgstr ""
"CFLAGS='-D_LARGEFILE64_SOURCE -D_FILE_OFFSET_BITS=64' OPT=\"-g -O2 $CFLAGS\" "
"\\\n"
"        ./configure"

#: ../../library/posix.rst:67
msgid "Notable Module Contents"
msgstr "–Я—А–Є–Љ–µ—З–∞—В–µ–ї—М–љ–Њ–µ —Б–Њ–і–µ—А–ґ–Є–Љ–Њ–µ –Љ–Њ–і—Г–ї—П"

#: ../../library/posix.rst:69
msgid ""
"In addition to many functions described in the :mod:`os` module "
"documentation, :mod:`posix` defines the following data item:"
msgstr ""
"–Т –і–Њ–њ–Њ–ї–љ–µ–љ–Є–µ –Ї–Њ –Љ–љ–Њ–≥–Є–Љ —Д—Г–љ–Ї—Ж–Є—П–Љ, –Њ–њ–Є—Б–∞–љ–љ—Л–Љ –≤ –і–Њ–Ї—Г–Љ–µ–љ—В–∞—Ж–Є–Є "
"–Љ–Њ–і—Г–ї—П :mod:`os`, :mod:`posix` –Њ–њ—А–µ–і–µ–ї—П–µ—В —Б–ї–µ–і—Г—О—Й–Є–є —Н–ї–µ–Љ–µ–љ—В –і–∞–љ–љ—Л—Е:"

#: ../../library/posix.rst:74
msgid ""
"A dictionary representing the string environment at the time the interpreter "
"was started. Keys and values are bytes on Unix and str on Windows. For "
"example, ``environ[b'HOME']`` (``environ['HOME']`` on Windows) is the "
"pathname of your home directory, equivalent to ``getenv(\"HOME\")`` in C."
msgstr ""
"–°–ї–Њ–≤–∞—А—М, –њ—А–µ–і—Б—В–∞–≤–ї—П—О—Й–Є–є —Б—В—А–Њ–Ї–Њ–≤—Г—О —Б—А–µ–і—Г –љ–∞ –Љ–Њ–Љ–µ–љ—В –Ј–∞–њ—Г—Б–Ї–∞ –Є–љ—В–µ—А–њ—А–µ—В–∞—В–Њ—А–∞. "
"–Ъ–ї—О—З–Є –Є –Ј–љ–∞—З–µ–љ–Є—П –њ—А–µ–і—Б—В–∞–≤–ї—П—О—В —Б–Њ–±–Њ–є –±–∞–є—В—Л –≤ Unix –Є str –≤ Windows. –Э–∞–њ—А–Є–Љ–µ—А, "
"``environ[b'HOME']`` (``environ['HOME']`` –≤ Windows) вАФ —Н—В–Њ –њ—Г—В—М –Ї –≤–∞—И–µ–Љ—Г "
"–і–Њ–Љ–∞—И–љ–µ–Љ—Г –Ї–∞—В–∞–ї–Њ–≥—Г, —Н–Ї–≤–Є–≤–∞–ї–µ–љ—В–љ—Л–є ``getenv(\"HOME\")`` –≤ C. ."

#: ../../library/posix.rst:79
msgid ""
"Modifying this dictionary does not affect the string environment passed on "
"by :func:`~os.execv`, :func:`~os.popen` or :func:`~os.system`; if you need "
"to change the environment, pass ``environ`` to :func:`~os.execve` or add "
"variable assignments and export statements to the command string "
"for :func:`~os.system` or :func:`~os.popen`."
msgstr ""
"–Ш–Ј–Љ–µ–љ–µ–љ–Є–µ —Н—В–Њ–≥–Њ —Б–ї–Њ–≤–∞—А—П –љ–µ –≤–ї–Є—П–µ—В –љ–∞ —Б—В—А–Њ–Ї–Њ–≤—Г—О —Б—А–µ–і—Г, "
"–њ–µ—А–µ–і–∞–≤–∞–µ–Љ—Г—О :func:`~os.execv`, :func:`~os.popen` –Є–ї–Є :func:`~os.system`; "
"–µ—Б–ї–Є –≤–∞–Љ –љ—Г–ґ–љ–Њ –Є–Ј–Љ–µ–љ–Є—В—М —Б—А–µ–і—Г, –њ–µ—А–µ–і–∞–є—В–µ ``environ`` –≤ :func:`~os.execve` "
"–Є–ї–Є –і–Њ–±–∞–≤—М—В–µ –љ–∞–Ј–љ–∞—З–µ–љ–Є—П –њ–µ—А–µ–Љ–µ–љ–љ—Л—Е –Є –Њ–њ–µ—А–∞—В–Њ—А—Л —Н–Ї—Б–њ–Њ—А—В–∞ –≤ –Ї–Њ–Љ–∞–љ–і–љ—Г—О —Б—В—А–Њ–Ї—Г "
"–і–ї—П :func:`~os.system` –Є–ї–Є :func:` ~os.popen`."

#: ../../library/posix.rst:85
msgid "On Unix, keys and values are bytes."
msgstr "–Т Unix –Ї–ї—О—З–Є –Є –Ј–љ–∞—З–µ–љ–Є—П –њ—А–µ–і—Б—В–∞–≤–ї—П—О—В —Б–Њ–±–Њ–є –±–∞–є—В—Л."

#: ../../library/posix.rst:90
msgid ""
"The :mod:`os` module provides an alternate implementation of ``environ`` "
"which updates the environment on modification. Note also that "
"updating :data:`os.environ` will render this dictionary obsolete. Use of "
"the :mod:`os` module version of this is recommended over direct access to "
"the :mod:`posix` module."
msgstr ""
"–Ь–Њ–і—Г–ї—М :mod:`os` –њ—А–µ–і–Њ—Б—В–∞–≤–ї—П–µ—В –∞–ї—М—В–µ—А–љ–∞—В–Є–≤–љ—Г—О —А–µ–∞–ї–Є–Ј–∞—Ж–Є—О ``environ``, "
"–Ї–Њ—В–Њ—А–∞—П –Њ–±–љ–Њ–≤–ї—П–µ—В —Б—А–µ–і—Г –њ—А–Є –Є–Ј–Љ–µ–љ–µ–љ–Є–Є. –Ґ–∞–Ї–ґ–µ –Њ–±—А–∞—В–Є—В–µ –≤–љ–Є–Љ–∞–љ–Є–µ, —З—В–Њ "
"–Њ–±–љ–Њ–≤–ї–µ–љ–Є–µ :data:`os.environ` —Б–і–µ–ї–∞–µ—В —Н—В–Њ—В —Б–ї–Њ–≤–∞—А—М —Г—Б—В–∞—А–µ–≤—И–Є–Љ. –Ш—Б–њ–Њ–ї—М–Ј–Њ–≤–∞–љ–Є–µ "
"–≤–µ—А—Б–Є–Є –Љ–Њ–і—Г–ї—П :mod:`os` —А–µ–Ї–Њ–Љ–µ–љ–і—Г–µ—В—Б—П –≤–Љ–µ—Б—В–Њ –њ—А—П–Љ–Њ–≥–Њ –і–Њ—Б—В—Г–њ–∞ –Ї "
"–Љ–Њ–і—Г–ї—О :mod:`posix`."

